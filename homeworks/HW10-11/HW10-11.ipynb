   "source": [
    "import time\n",
    "import math\n",
    "import copy\n",
    "import pandas as pd\n",
    "import os\n",
    "import torch.nn as nn\n",
    "from torchvision.models import resnet18, ResNet18_Weights\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "def log_experiment_to_csv(exp_id, task, dataset, seed, model_name, opt_name, lr, epochs, \n",
    "                          best_val_acc=None, test_acc=None, precision=None, recall=None, mean_iou=None, notes=\"\"):\n",
    "    filename = \"artifacts/runs.csv\"\n",
    "    os.makedirs(os.path.dirname(filename), exist_ok=True)\n",
    "    \n",
    "    row = {\n",
    "        \"experiment_id\": exp_id, \"task\": task, \"dataset\": dataset, \"seed\": seed,\n",
    "        \"model_summary\": model_name, \"optimizer\": opt_name, \"lr\": lr, \"epochs_trained\": epochs,\n",
    "        \"best_val_accuracy\": round(best_val_acc, 4) if best_val_acc else \"\",\n",
    "        \"test_accuracy\": round(test_acc, 4) if test_acc else \"\",\n",
    "        \"precision\": round(precision, 4) if precision else \"\",\n",
    "        \"recall\": round(recall, 4) if recall else \"\",\n",
    "        \"mean_iou\": round(mean_iou, 4) if mean_iou else \"\",\n",
    "        \"notes\": notes\n",
    "    }\n",
    "    df = pd.DataFrame([row])\n",
    "    if not os.path.isfile(filename):\n",
    "        df.to_csv(filename, index=False)\n",
    "    else:\n",
    "        df.to_csv(filename, mode='a', header=False, index=False)\n",
    "\n",
    "\n",
    "EPOCHS = 5 \n",
    "NUM_CLASSES = 100 \n",
    "\n",
    "def get_cifar100_loaders(train_transform, eval_transform):\n",
    "\n",
    "    full_train_ds = torchvision.datasets.CIFAR100(root=DATA_ROOT, train=True, download=False, transform=train_transform)\n",
    "\n",
    "    full_val_ds = torchvision.datasets.CIFAR100(root=DATA_ROOT, train=True, download=False, transform=eval_transform)\n",
    "\n",
    "    test_ds = torchvision.datasets.CIFAR100(root=DATA_ROOT, train=False, download=False, transform=eval_transform)\n",
    "    \n",
    "    gen = torch.Generator().manual_seed(42)\n",
    "    train_size = int(0.8 * len(full_train_ds))\n",
    "    val_size = len(full_train_ds) - train_size\n",
    "\n",
    "    indices = torch.randperm(len(full_train_ds), generator=gen).tolist()\n",
    "    train_idx = indices[:train_size]\n",
    "    val_idx = indices[train_size:]\n",
    "    \n",
    "    train_subset = torch.utils.data.Subset(full_train_ds, train_idx)\n",
    "    val_subset = torch.utils.data.Subset(full_val_ds, val_idx)\n",
    "    \n",
    "    tr_loader = DataLoader(train_subset, batch_size=BATCH_SIZE, shuffle=True, num_workers=2)\n",
    "    v_loader = DataLoader(val_subset, batch_size=BATCH_SIZE, shuffle=False, num_workers=2)\n",
    "    te_loader = DataLoader(test_ds, batch_size=BATCH_SIZE, shuffle=False, num_workers=2)\n",
    "    \n",
    "    return tr_loader, v_loader, te_loader\n",
    "\n",
    "class SimpleCNN(nn.Module):\n",
    "    def __init__(self, num_classes=100):\n",
    "        super().__init__()\n",
    "        self.features = nn.Sequential(\n",
    "            nn.Conv2d(3, 32, kernel_size=3, padding=1), nn.ReLU(), nn.MaxPool2d(2),\n",
    "            nn.Conv2d(32, 64, kernel_size=3, padding=1), nn.ReLU(), nn.MaxPool2d(2),\n",
    "            nn.Conv2d(64, 128, kernel_size=3, padding=1), nn.ReLU(), nn.MaxPool2d(2),\n",
    "        )\n",
    "        self.classifier = nn.Sequential(\n",
    "            nn.Flatten(), nn.Linear(128 * 4 * 4, 256), nn.ReLU(), nn.Linear(256, num_classes)\n",
    "        )\n",
    "    def forward(self, x):\n",
    "        return self.classifier(self.features(x))\n",
    "\n",
    "def fit(model, train_loader, val_loader, optimizer, criterion, epochs=EPOCHS, exp_name=\"Exp\"):\n",
    "    best_acc = 0.0\n",
    "    best_weights = copy.deepcopy(model.state_dict())\n",
    "    history = {\"train_loss\": [], \"train_acc\": [], \"val_loss\": [], \"val_acc\": []}\n",
    "    \n",
    "    print(f\"\\nНачинаем {exp_name}...\")\n",
    "    for epoch in range(1, epochs + 1):\n",
    "        tr_loss, tr_acc = train_one_epoch(model, train_loader, criterion, optimizer, device)\n",
    "        va_loss, va_acc = evaluate(model, val_loader, criterion, device)\n",
    "        history[\"train_loss\"].append(tr_loss); history[\"train_acc\"].append(tr_acc)\n",
    "        history[\"val_loss\"].append(va_loss); history[\"val_acc\"].append(va_acc)\n",
    "        \n",
    "        if va_acc > best_acc:\n",
    "            best_acc = va_acc\n",
    "            best_weights = copy.deepcopy(model.state_dict())\n",
    "        print(f\"Epoch {epoch:02d} | TL: {tr_loss:.3f}, TA: {tr_acc:.3f} | VL: {va_loss:.3f}, VA: {va_acc:.3f}\")\n",
    "        \n",
    "    model.load_state_dict(best_weights)\n",
    "    return history, best_acc, model\n"
   ]
