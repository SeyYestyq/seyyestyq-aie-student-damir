    "from torchvision.models.segmentation import deeplabv3_resnet50, DeepLabV3_ResNet50_Weights\n",
    "from torchvision.transforms import functional as F\n",
    "import cv2\n",
    "\n",
    "weights = DeepLabV3_ResNet50_Weights.COCO_WITH_VOC_LABELS_V1\n",
    "seg_model = deeplabv3_resnet50(weights=weights).to(device)\n",
    "seg_model.eval()\n",
    "seg_preprocess = weights.transforms()\n",
    "\n",
    "CAT_IDX, DOG_IDX = 8, 12\n",
    "\n",
    "@torch.no_grad()\n",
    "def get_prediction(img_pil):\n",
    "    x = seg_preprocess(img_pil).unsqueeze(0).to(device)\n",
    "    pred = seg_model(x)[\"out\"][0].argmax(0).cpu()  \n",
    "    return ((pred == CAT_IDX) | (pred == DOG_IDX)).to(torch.uint8), x.shape[-2:]\n",
    "\n",
    "def eval_segmentation(postprocess_fn=None):\n",
    "    ious = []; fig, axes = plt.subplots(3, 3, figsize=(10, 8)); show_idx = 0\n",
    "    for i in range(10): \n",
    "        img_pil, gt_mask_pil = pet_dataset[i]\n",
    "        pred_mask_tensor, (h, w) = get_prediction(img_pil)\n",
    "        \n",
    "        if postprocess_fn is not None:\n",
    "            pred_mask_tensor = torch.from_numpy(postprocess_fn(pred_mask_tensor.numpy()))\n",
    "            \n",
    "        gt_rs = F.resize(gt_mask_pil, size=[h, w], interpolation=F.InterpolationMode.NEAREST)\n",
    "        gt_binary = (torch.from_numpy(np.array(gt_rs)) == 1).to(torch.uint8)\n",
    "        \n",
    "        iou = calculate_iou(pred_mask_tensor, gt_binary, class_id=1)\n",
    "        ious.append(iou)\n",
    "        \n",
    "        if show_idx < 3:\n",
    "            axes[show_idx, 0].imshow(np.array(F.resize(img_pil, size=[h, w]))); axes[show_idx, 0].axis('off')\n",
    "            axes[show_idx, 1].imshow(gt_binary.numpy(), cmap='viridis'); axes[show_idx, 1].axis('off')\n",
    "            axes[show_idx, 2].imshow(pred_mask_tensor.numpy(), cmap='viridis'); axes[show_idx, 2].axis('off')\n",
    "            axes[show_idx, 2].set_title(f\"IoU: {iou:.3f}\")\n",
    "            show_idx += 1\n",
    "    plt.tight_layout()\n",
    "    return np.mean(ious), fig\n",
    "\n",
    "# V1\n",
    "print(\" V1: Базовая маска \")\n",
    "mean_iou_v1, fig_v1 = eval_segmentation(None)\n",
    "fig_v1.savefig(\"artifacts/figures/segmentation_examples_v1.png\")\n",
    "log_experiment_to_csv(\"V1\", \"segmentation\", \"OxfordIIITPet\", 42, \"DeepLabV3_ResNet50\", \"-\", \"-\", \"-\", mean_iou=mean_iou_v1, notes=\"Base mask thresholding\")\n",
    "\n",
    "#  V2\n",
    "print(\"\\n V2: Морфологическая очистка \")\n",
    "def morphological_clean(mask_np):\n",
    "    return cv2.morphologyEx(mask_np, cv2.MORPH_OPEN, np.ones((5, 5), np.uint8))\n",
    "mean_iou_v2, fig_v2 = eval_segmentation(morphological_clean)\n",
    "fig_v2.savefig(\"artifacts/figures/segmentation_examples_v2.png\")\n",
    "log_experiment_to_csv(\"V2\", \"segmentation\", \"OxfordIIITPet\", 42, \"DeepLabV3_ResNet50\", \"-\", \"-\", \"-\", mean_iou=mean_iou_v2, notes=\"Morphological opening applied\")\n",
    "\n",
    "plt.figure(figsize=(6,4)); plt.bar([\"V1 Base\", \"V2 Morph\"], [mean_iou_v1, mean_iou_v2]); plt.title(\"Mean IoU\"); plt.savefig(\"artifacts/figures/segmentation_metrics.png\"); plt.show()\n"
   ]
