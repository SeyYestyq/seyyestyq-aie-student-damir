    "# 2.4.3. Базовые функции обучения и оценки\n",
    "import pandas as pd\n",
    "\n",
    "# 2.4.3. ЧАСТЬ A: Функции обучения и оценки (Классификация)\n",
    "\n",
    "def train_one_epoch(model, dataloader, criterion, optimizer, device):\n",
    "\n",
    "    model.train() \n",
    "    running_loss = 0.0\n",
    "    correct = 0\n",
    "    total = 0\n",
    "    \n",
    "    for inputs, labels in dataloader:\n",
    "\n",
    "        inputs, labels = inputs.to(device), labels.to(device)\n",
    "        \n",
    "\n",
    "        optimizer.zero_grad()\n",
    "\n",
    "        outputs = model(inputs)\n",
    "        loss = criterion(outputs, labels)\n",
    "\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "\n",
    "        running_loss += loss.item() * inputs.size(0)\n",
    "        _, predicted = outputs.max(1)\n",
    "        total += labels.size(0)\n",
    "        correct += predicted.eq(labels).sum().item()\n",
    "        \n",
    "    epoch_loss = running_loss / total\n",
    "    epoch_acc = correct / total\n",
    "    \n",
    "    return epoch_loss, epoch_acc\n",
    "\n",
    "def evaluate(model, dataloader, criterion, device):\n",
    "\n",
    "    model.eval() \n",
    "    running_loss = 0.0\n",
    "    correct = 0\n",
    "    total = 0\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for inputs, labels in dataloader:\n",
    "            inputs, labels = inputs.to(device), labels.to(device)\n",
    "            \n",
    "            outputs = model(inputs)\n",
    "            loss = criterion(outputs, labels)\n",
    "            \n",
    "            running_loss += loss.item() * inputs.size(0)\n",
    "            _, predicted = outputs.max(1)\n",
    "            total += labels.size(0)\n",
    "            correct += predicted.eq(labels).sum().item()\n",
    "            \n",
    "    epoch_loss = running_loss / total\n",
    "    epoch_acc = correct / total\n",
    "    \n",
    "    return epoch_loss, epoch_acc\n",
    "\n",
    "\n",
    "# 2.4.3. ЧАСТЬ B: Функции для Сегментации (OxfordIIITPet)\n",
    "\n",
    "\n",
    "def calculate_iou(pred_mask, gt_mask, class_id=1):\n",
    "\n",
    "    # Превращаем тензоры в булевы маски для искомого класса\n",
    "    pred_inds = (pred_mask == class_id)\n",
    "    gt_inds = (gt_mask == class_id)\n",
    "    \n",
    "    intersection = (pred_inds & gt_inds).sum().item()\n",
    "    union = (pred_inds | gt_inds).sum().item()\n",
    "    \n",
    "    if union == 0:\n",
    "        return 0.0 # Избегаем деления на ноль\n",
    "    \n",
    "    return intersection / union\n",
    "\n",
    "def visualize_segmentation_predictions(image_tensor, gt_mask_tensor, pred_mask_tensor):\n",
    "\n",
    "    # Денормализация картинки для красивого вывода (если применяли ImageNet нормализацию)\n",
    "    img = image_tensor.cpu().numpy().transpose((1, 2, 0))\n",
    "    mean = np.array([0.485, 0.456, 0.406])\n",
    "    std = np.array([0.229, 0.224, 0.225])\n",
    "    img = std * img + mean\n",
    "    img = np.clip(img, 0, 1)\n",
    "    \n",
    "    fig, axes = plt.subplots(1, 3, figsize=(12, 4))\n",
    "    \n",
    "    axes[0].imshow(img)\n",
    "    axes[0].set_title(\"Оригинал\")\n",
    "    axes[0].axis('off')\n",
    "    \n",
    "    axes[1].imshow(gt_mask_tensor.cpu().numpy(), cmap='viridis')\n",
    "    axes[1].set_title(\"Ground Truth (Истинная)\")\n",
    "    axes[1].axis('off')\n",
    "    \n",
    "    axes[2].imshow(pred_mask_tensor.cpu().numpy(), cmap='viridis')\n",
    "    iou_score = calculate_iou(pred_mask_tensor, gt_mask_tensor, class_id=1)\n",
    "    axes[2].set_title(f\"Предсказание (IoU: {iou_score:.3f})\")\n",
    "    axes[2].axis('off')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Логирование результатов\n",
    "\n",
    "def log_to_csv(experiment_name, task, metric_name, metric_value, filename=\"artifacts/runs.csv\"):\n",
    "    os.makedirs(os.path.dirname(filename), exist_ok=True)\n",
    "    \n",
    "    new_row = pd.DataFrame([{\n",
    "        \"Experiment\": experiment_name,\n",
    "        \"Task\": task,\n",
    "        \"Metric\": metric_name,\n",
    "        \"Value\": round(metric_value, 4)\n",
    "    }])\n",
    "    \n",
    "    if not os.path.isfile(filename):\n",
    "        new_row.to_csv(filename, index=False)\n",
    "    else:\n",
    "        new_row.to_csv(filename, mode='a', header=False, index=False)\n",
    "        \n",
    "    print(f\"Результат [{experiment_name}] сохранен в {filename}\")"
   ]
