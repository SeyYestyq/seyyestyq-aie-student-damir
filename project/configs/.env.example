# Drop Forecaster — Environment Configuration
# Copy this file to .env and fill in values

#  Model 
MODEL_PATH=artifacts/drop_forecaster.cbm
MODEL_VERSION=1.0.0

#  API 
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_LOG_LEVEL=INFO

#  Features 
ENABLE_BATCH_PREDICT=true
MAX_BATCH_SIZE=100

#  Logging 
LOG_FORMAT=json
LOG_FILE=logs/api.log
